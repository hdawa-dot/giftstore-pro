# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/giftstore

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin Credentials (will be seeded)
ADMIN_EMAIL=admin@giftstore.com
ADMIN_PASSWORD=Admin@123456

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GiftStore Pro

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=GiftStore Pro <noreply@giftstore.com>

# Binance API (for USDT price)
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000
